{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:db": "ts-node-dev --transpile-only src/scripts/test-db.ts",
    "seed:users": "ts-node-dev --transpile-only src/scripts/seed-users.ts"
  },
  "dependencies": {
    "@evergreen/shared-types": "*",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.2.0",
    "helmet": "^8.0.0",
    "mongoose": "^9.1.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "private": true
}
