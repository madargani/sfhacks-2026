{
  "name": "evergreen",
  "version": "1.0.0",
  "description": "Mobile carpool organization app centered around sustainability",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=mobile",
    "backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "keywords": [
    "carpool",
    "sustainability",
    "mobile",
    "expo",
    "mongodb"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.5",
    "react-native-maps": "^1.27.1"
  }
}
